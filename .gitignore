cat > .gitignore <<'EOF'
#============================================================
# Vivado generated folders
#============================================================

.Xil/
**/.Xil/

*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.gen/

**/*.cache/
**/*.hw/
**/*.ip_user_files/
**/*.runs/
**/*.sim/
**/*.gen/

#============================================================
# Vivado temporary / log / journal files
#============================================================

*.jou
*.log
*.str
*.wdb
*.pb
*.backup
*.bak
*.tmp

#============================================================
# Vivado implementation intermediate files
#============================================================

*.dcp
*.rpt
*.rpx
*.xml
*.html
*.csv

#============================================================
# Simulation temporary files
#============================================================

xsim.dir/
**/xsim.dir/
*.vcd
*.saif

#============================================================
# Windows system files
#============================================================

Thumbs.db
Desktop.ini

#============================================================
# Keep important project result files
#============================================================
!README.md
!**/*.v
!**/*.sv
!**/*.vh
!**/*.xdc
!**/*.tcl
!**/*.m
!**/*.mem
!**/*.coe
!**/*.txt
!**/*.md
!**/*.bit
!**/*.png
!**/*.jpg
!**/*.jpeg
EOF